# LTI 1.3 Configuration
LTI_ISSUER=https://blackboard.learn.instance.com
LTI_CLIENT_ID=your-client-id-from-blackboard
LTI_DEPLOYMENT_ID=your-deployment-id
LTI_AUTHORIZATION_ENDPOINT=https://blackboard.learn.instance.com/learn/api/public/v1/oauth2/authorizationcode
LTI_TOKEN_ENDPOINT=https://blackboard.learn.instance.com/learn/api/public/v1/oauth2/token
LTI_JWKS_ENDPOINT=https://blackboard.learn.instance.com/learn/api/public/v1/oauth2/jwks

# WordPress Integration
WP_API_BASE=https://icnpaim.cl/wp-json/wp/v2
# Choose one authentication method:
# Option A: Basic Auth with Application Password
WORDPRESS_API_USER=your-wp-api-user
WORDPRESS_API_PASSWORD=your-wp-application-password
# Option B: Basic Auth (base64 encoded)
# WP_BASIC_AUTH=Basic <base64(username:application-password)>
# Option C: JWT Token
# WP_JWT=eyJhbGciOi...

# Application Settings
SESSION_SECRET=change-me-in-production
NODE_ENV=development
PORT=8080