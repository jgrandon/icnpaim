{
    "env": {
        "browser": true,
        "es2021": true,
        "node": true
    },
    "extends": [
        "eslint:recommended",
        "plugin:react/recommended"
    ],
    "parserOptions": {
        "ecmaFeatures": {
            "jsx": true
        },
        "ecmaVersion": 12,
        "sourceType": "module"
    },
    "plugins": [
        "react"
    ],
    "rules": {
        "indent": [
            "error",
            4
        ],
        "linebreak-style": [
            "error",
            "windows"
        ],
        "quotes": [
            "error",
            "single"
        ],
        "semi": [
            "warn",
            "never"
        ],
        "array-bracket-spacing": [
            "warn",
            "always"
        ],
        "jsx-quotes": [
            "warn",
            "prefer-single"
        ],
        
        "react/display-name": [
            "off"
        ],
        "react/prop-types": "off"
    },
  "ignorePatterns": [
    "*.md",
    "/server/database/**/*.json"
  ]
}
